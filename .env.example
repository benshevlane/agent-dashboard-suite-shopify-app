# Copy to .env (local) or set these as Environment Variables in Vercel.
# The app is stateless — no database to configure.

# --- Shopify (from the Partner Dashboard > your app > API credentials) ---
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_products,read_content,read_themes
# Your public app URL (the Vercel URL once deployed).
SHOPIFY_APP_URL=https://your-app.vercel.app

# --- Ralf backend (already deployed) ---
RALF_API_BASE=https://ewkrubluzctsfnkxnmsj.supabase.co/functions/v1/shopify-app-api
# Shared secret; must match shopify_app_config.ralf_app_secret on the Ralf side.
RALF_APP_SECRET=
