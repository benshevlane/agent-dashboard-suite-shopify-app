# Copy to .env and fill in. The Shopify values come from your Partner Dashboard
# app; the Ralf values connect this app to the deployed Ralf backend.

# --- Shopify (from the Partner Dashboard > your app > API credentials) ---
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_products,read_content,read_themes
SHOPIFY_APP_URL=https://your-tunnel-or-host-url

# --- Ralf backend (already deployed) ---
# Base URL of the Ralf shopify-app-api edge function.
RALF_API_BASE=https://ewkrubluzctsfnkxnmsj.supabase.co/functions/v1/shopify-app-api
# Shared secret the app sends on the connect call. MUST match the
# RALF_SHOPIFY_APP_SECRET value set on the Ralf Supabase project.
RALF_APP_SECRET=

# --- Local session DB (Prisma) ---
DATABASE_URL="file:dev.sqlite"
