// Local persistence for the Shopify app.
//  - Session: required by @shopify/shopify-app-session-storage-prisma.
//  - RalfMerchant: maps a shop to its Ralf per-merchant API key (returned by
//    the Ralf `connect` call at install time) so every screen can authenticate
//    to the Ralf backend.
// SQLite is fine for dev. For production, switch the provider to postgresql and
// point DATABASE_URL at a hosted Postgres (the Ralf Supabase DB works well).

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

model RalfMerchant {
  shop        String   @id
  ralfApiKey  String
  siteId      String?
  accountId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
